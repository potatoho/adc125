set_property PACKAGE_PIN L16 [get_ports {adc1_data_n[3]}]
set_property PACKAGE_PIN L15 [get_ports {adc1_data_p[4]}]
set_property PACKAGE_PIN K15 [get_ports {adc1_data_n[4]}]
set_property PACKAGE_PIN E18 [get_ports {adc1_data_p[5]}]
set_property PACKAGE_PIN E17 [get_ports {adc1_data_n[5]}]
set_property PACKAGE_PIN J16 [get_ports {adc1_data_p[6]}]
set_property PACKAGE_PIN J15 [get_ports {adc1_data_n[6]}]
set_property PACKAGE_PIN H16 [get_ports {adc1_data_p[7]}]
set_property PACKAGE_PIN G16 [get_ports {adc1_data_n[7]}]
set_property PACKAGE_PIN G18 [get_ports {adc1_data_p[8]}]
set_property PACKAGE_PIN F18 [get_ports {adc1_data_n[8]}]
set_property PACKAGE_PIN A13 [get_ports {adc1_data_p[9]}]
set_property PACKAGE_PIN A12 [get_ports {adc1_data_n[9]}]
set_property PACKAGE_PIN G15 [get_ports {adc1_data_p[10]}]
set_property PACKAGE_PIN F15 [get_ports {adc1_data_n[10]}]
set_property PACKAGE_PIN C13 [get_ports {adc1_data_p[11]}]
set_property PACKAGE_PIN C12 [get_ports {adc1_data_n[11]}]

set_property IOSTANDARD LVDS [get_ports {adc1_data_p[*]}]
set_property IOSTANDARD LVDS [get_ports {adc1_data_n[*]}]
set_property DIFF_TERM TRUE [get_ports {adc1_data_p[*]}]
set_property DIFF_TERM TRUE [get_ports {adc1_data_n[*]}]


## ============================================================
## ADC1 SPI
## ============================================================

set_property PACKAGE_PIN K19 [get_ports adc1_spi_ce]
set_property PACKAGE_PIN H17 [get_ports adc1_spi_sclk]
set_property PACKAGE_PIN K18 [get_ports adc1_spi_io]

set_property IOSTANDARD LVCMOS18 [get_ports {adc1_spi_ce adc1_spi_sclk adc1_spi_io}]


## ============================================================
## ADC2 DCO Input : FL9627 -> FPGA
