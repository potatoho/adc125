## ============================================================
## ADC Encode Clock Output : FPGA -> FL9627
## ============================================================

set_property PACKAGE_PIN H18 [get_ports adc1_clk_ref]
set_property PACKAGE_PIN F11 [get_ports adc2_clk_ref]

set_property IOSTANDARD LVCMOS18 [get_ports {adc1_clk_ref adc2_clk_ref}]
set_property SLEW FAST [get_ports {adc1_clk_ref adc2_clk_ref}]
set_property DRIVE 8 [get_ports {adc1_clk_ref adc2_clk_ref}]


## ============================================================
## ZCU104 System Clock Input
## create_clock is generated by clk_wiz_0_in_context.xdc
## ============================================================

set_property PACKAGE_PIN F23 [get_ports sys_clk_p]
set_property PACKAGE_PIN E23 [get_ports sys_clk_n]
set_property IOSTANDARD LVDS [get_ports {sys_clk_p sys_clk_n}]


## ============================================================
## ADC1 DCO Input : FL9627 -> FPGA
## ============================================================

set_property PACKAGE_PIN F17 [get_ports adc1_clk_p]
set_property PACKAGE_PIN F16 [get_ports adc1_clk_n]

set_property IOSTANDARD LVDS [get_ports {adc1_clk_p adc1_clk_n}]
set_property DIFF_TERM TRUE [get_ports {adc1_clk_p adc1_clk_n}]

create_clock -name adc1_dco_clk -period 8.000 [get_ports adc1_clk_p]


## ============================================================
## ADC1 LVDS Data Input
## ============================================================

set_property PACKAGE_PIN L20 [get_ports {adc1_data_p[0]}]
set_property PACKAGE_PIN K20 [get_ports {adc1_data_n[0]}]
set_property PACKAGE_PIN H19 [get_ports {adc1_data_p[1]}]
set_property PACKAGE_PIN G19 [get_ports {adc1_data_n[1]}]
